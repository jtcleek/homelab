{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "labels": [
    "renovate"
  ],
  "configMigration": true,
  "prHourlyLimit": 0,
  "pruneStaleBranches": true,
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "valkey"
      ],
      "matchFileNames": [
        "stacks/immich/compose.yaml"
      ],
      "enabled": false
    }
  ]
}
